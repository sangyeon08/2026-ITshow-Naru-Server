{
  "name": "naru-backend-api",
  "version": "1.0.0",
  "description": "Naru food delivery app backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "start:dev": "npm run dev",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node scripts/seed.ts",
    "gen:types": "npx supabase gen types typescript --project-id gsqqrwtcuutchzooirgf --schema public > src/types/database.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
